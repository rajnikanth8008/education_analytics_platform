    {
      "name": "a13e8ffb",
      "displayName": "gold_kpi_summary",
      "queryLines": [
        "--SELECT * FROM myworkspace.education_db.gold_kpi_summary\n",
        "\n",
        "SELECT total_students_enrolled   AS `Total Students Enrolled`,\n",
        "  total_schools             AS `Total Schools`,\n",
        "  overall_avg_score         AS `Avg Performance Score`,\n",
        "  overall_dropout_pct       AS `Overall Dropout %`,\n",
        "  high_risk_count           AS `High Risk Count`,\n",
        "  avg_budget_usd            AS `Avg Budget Per Student (USD)`\n",
        "FROM education_db.gold_kpi_summary;\n",
        "\n",
        "\n",
        "SELECT high_risk_count AS `High Risk Schools`\n",
        "FROM education_db.gold_kpi_summary"
      ]
    }
